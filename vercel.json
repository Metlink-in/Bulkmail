{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "main.py" },
    { "src": "/health",   "dest": "main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)",     "dest": "public/$1" }
  ],
  "env": {
    "APP_ENV": "production"
  }
}
